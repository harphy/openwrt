+#ifdef CONFIG_DEBUG_FS
+static ssize_t
+mt7530_debugfs_reg_read(struct file *file, char __user *user_buf,
+				       size_t count, loff_t *ppos)
+{
+	struct mt7530_priv *priv = file->private_data;
+	char buf[64];
+	u32 val;
+	int len;
+
+	val = mt7530_read(priv, priv->debugfs_reg);
+	len = snprintf(buf, sizeof(buf), "reg: 0x%04x, value: 0x%08x\n",
+		       priv->debugfs_reg, val);
+
+	return simple_read_from_buffer(user_buf, count, ppos, buf, len);
+}
+
+static ssize_t
+mt7530_debugfs_reg_write(struct file *file,
+					const char __user *user_buf,
+					size_t count, loff_t *ppos)
+{
+	struct mt7530_priv *priv = file->private_data;
+	char buf[32];
+	size_t buf_size;
+	u32 reg;
+	int ret;
+
+	buf_size = min(count, sizeof(buf) - 1);
+	if (copy_from_user(buf, user_buf, buf_size))
+		return -EFAULT;
+
+	buf[buf_size] = '\0';
+	ret = kstrtou32(buf, 0, &reg);
+	if (ret)
+		return ret;
+
+	priv->debugfs_reg = reg;
+	return count;
+}
+
+static const struct file_operations mt7530_debugfs_reg_fops = {
+	.owner = THIS_MODULE,
+	.open = simple_open,
+	.read = mt7530_debugfs_reg_read,
+	.write = mt7530_debugfs_reg_write,
+	.llseek = default_llseek,
+};
+
+static ssize_t
+mt7530_debugfs_regw_write(struct file *file,
+					 const char __user *user_buf,
+					 size_t count, loff_t *ppos)
+{
+	struct mt7530_priv *priv = file->private_data;
+	char buf[64];
+	size_t buf_size;
+	u32 reg, val;
+	int ret;
+
+	buf_size = min(count, sizeof(buf) - 1);
+	if (copy_from_user(buf, user_buf, buf_size))
+		return -EFAULT;
+
+	buf[buf_size] = '\0';
+
+	/* 解析格式: "reg val" 或 "reg,val" */
+	ret = sscanf(buf, "%i %i", &reg, &val);
+	if (ret != 2) {
+		ret = sscanf(buf, "%i,%i", &reg, &val);
+		if (ret != 2)
+			return -EINVAL;
+	}
+
+	/* 写入寄存器 */
+	mt7530_write(priv, reg, val);
+
+	return count;
+}
+
+static const struct file_operations mt7530_debugfs_regw_fops = {
+	.owner = THIS_MODULE,
+	.open = simple_open,
+	.write = mt7530_debugfs_regw_write,
+	.llseek = default_llseek,
+};
+
+static int
+mt7530_debugfs_init(struct mt7530_priv *priv)
+{
+	struct dentry *dir;
+
+	dir = debugfs_create_dir("mt7530", NULL);
+	if (IS_ERR(dir))
+		return PTR_ERR(dir);
+
+	priv->debugfs_dir = dir;
+	priv->debugfs_reg = 0;
+
+	debugfs_create_file("regs", 0600, dir, priv, &mt7530_debugfs_reg_fops);
+	debugfs_create_file("regw", 0200, dir, priv, &mt7530_debugfs_regw_fops);
+
+	return 0;
+}
+
+static void
+mt7530_debugfs_remove(struct mt7530_priv *priv)
+{
+	debugfs_remove_recursive(priv->debugfs_dir);
+	priv->debugfs_dir = NULL;
+}
+#else
+static inline int
+mt7530_debugfs_init(struct mt7530_priv *priv)
